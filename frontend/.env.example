# Frontend environment variables example
# Copy to .env or .env.local and fill values

# Expo public Google OAuth client id
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API base URL overrides if needed
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL_WEB=http://localhost:3000
EXPO_PUBLIC_API_URL_IOS=http://localhost:3000
EXPO_PUBLIC_API_URL_ANDROID=http://192.168.1.10:3000
